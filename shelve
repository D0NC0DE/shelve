#!/usr/bin/env bash
# =============================================================================
# shelve — main entry point
# =============================================================================

set -eo pipefail

SHELVE_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SHELVE_VERSION="0.1.0"

source "${SHELVE_ROOT}/lib/utils.sh"

# -----------------------------------------------------------------------------
# OS CHECK
# -----------------------------------------------------------------------------
if [[ "$(uname)" != "Darwin" ]]; then
  log_error "shelve only runs on macOS"
  exit 1
fi

# -----------------------------------------------------------------------------
# PREREQUISITES
# -----------------------------------------------------------------------------
check_prerequisites() {
  if ! xcode-select -p &>/dev/null; then
    log_error "Xcode CLI tools not installed"
    log_info "Run: xcode-select --install, then try again"
    exit 1
  fi

  if ! command_exists brew; then
    log_warn "Homebrew not found — installing now (you may be prompted for your password)..."
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    if [[ "$(uname -m)" == "arm64" ]]; then
      eval "$(/opt/homebrew/bin/brew shellenv)"
    fi
    log_success "Homebrew installed"
  fi

  if ! command_exists gum; then
    log_error "gum is required but not installed"
    log_info "Run: brew install gum"
    exit 1
  fi
}

# -----------------------------------------------------------------------------
# HELP
# -----------------------------------------------------------------------------
show_help() {
  shelve_banner
  divider
  printf "\n"
  printf "  ${BOLD}Usage:${RESET} shelve ${CYAN}<command>${RESET}\n\n"
  show_commands
  divider
  printf "\n  ${DIM}v${SHELVE_VERSION}${RESET}\n\n"
}

show_commands() {
  printf "  ${CYAN}save${RESET}       capture your current Mac setup\n"
  printf "  ${CYAN}restore${RESET}    restore from a saved config\n"
  printf "  ${CYAN}fresh${RESET}      spin up a brand new Mac from zero\n"
  printf "  ${CYAN}help${RESET}       show this help\n\n"
}

# -----------------------------------------------------------------------------
# COMMANDS
# -----------------------------------------------------------------------------
cmd="${1:-help}"

[[ "$cmd" != "help" && "$cmd" != "--help" && "$cmd" != "-h" ]] && check_prerequisites

case "$cmd" in
save)
  source "${SHELVE_ROOT}/lib/save.sh"
  cmd_save
  ;;
restore)
  source "${SHELVE_ROOT}/lib/restore.sh"
  cmd_restore
  ;;
fresh)
  source "${SHELVE_ROOT}/lib/fresh.sh"
  cmd_fresh
  ;;
help | --help | -h)
  show_help
  ;;
*)
  log_error "Unknown command: ${1}"
  printf "\n"
  show_commands
  exit 1
  ;;
esac
